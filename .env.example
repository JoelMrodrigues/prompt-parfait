# Frontend (Vite) - à configurer dans Vercel ou .env local
VITE_DPM_API_URL=https://ton-api.onrender.com
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Script create-team-users (clé service_role - NE PAS exposer côté client)
# Supabase Dashboard → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend (Express) - à configurer dans Render/Railway ou server/.env
# En local (dev) : le serveur utilise RIOT_API_KEY_TEST si défini, sinon RIOT_API_KEY
# En prod (NODE_ENV=production) : le serveur utilise uniquement RIOT_API_KEY
RIOT_API_KEY_TEST=RGAPI-xxxx   # clé de test pour le dev local (optionnel)
RIOT_API_KEY=RGAPI-xxxx        # clé prod (Railway / Render)
FRONTEND_URL=https://ton-app.vercel.app
